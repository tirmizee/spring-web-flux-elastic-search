{
  "analysis": {
    "analyzer": {
      "thai_html_analyzer": {
        "type": "custom",
        "char_filter": ["html_strip"],
        "tokenizer": "thai",
        "filter": ["lowercase", "thai_synonym", "stop"]
      },
      "en_html_analyzer": {
        "type": "custom",
        "char_filter": ["html_strip"],
        "tokenizer": "standard",
        "filter": ["lowercase", "thai_synonym", "english_stop", "english_stemmer"]
      }
    },
    "filter": {
      "english_stop": { "type": "stop", "stopwords": "_english_" },
      "english_stemmer": { "type": "stemmer", "language": "english" },
      "thai_synonym": {
        "type": "synonym",
        "synonyms": [
          "เอ็กซ์คลูซีฟ, เอ็กคลูซีฟ, exclusive",
          "สเปเชียล, สเปเชี่ยล, special",
          "พอยต์, พอยท์, พ้อย, point",
          "แคชแบ็ค, เครดิตเงินคืน, cashback",
          "เปอร์เซ็นต์, เปอร์เซนต์, percent"
        ]
      }
    }
  }
}